2026-03-19 06:33:04,901 p=209461 u=root n=ansible | TASK [MULTIPATH | /etc/multipath.conf - inventory WWID alias tanımları dest=/etc/multipath.conf, content=# Ansible tarafından yönetilir — hosts.yml → multipath_aliases
# WWID ve alias değişikliği için hosts.yml güncelleyin.
defaults {
    user_friendly_names no
    find_multipaths     yes
    enable_foreign      "^$"
}
blacklist {
    devnode "^(ram|raw|loop|fd|md|dm-|sr|scd|st)[0-9]*"
    devnode "^hd[a-z]"
    devnode "^vd[a-z]"
}
multipaths {
{% for entry in multipath_aliases %}
    multipath {
        wwid  {{ entry.wwid }}
        alias {{ entry.alias }}
    }
{% endfor %}
}
, mode=0644, owner=root, group=root] ***
